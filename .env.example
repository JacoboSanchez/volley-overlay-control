# Volley Overlay Control — environment template.
#
# Copy this file to ``.env`` and adjust the values for your deployment.
# Lines that are commented out fall back to the defaults shown after ``=``.
# Secrets (passwords, tokens) MUST NOT be committed alongside this template.

# ---- Network ----------------------------------------------------------------
# Host port to expose the container on. ``80`` is the default for production
# behind a reverse proxy; pick something like ``8080`` for local dev.
EXTERNAL_PORT=8080

# Internal listen port — match the value in the Dockerfile HEALTHCHECK if you
# change it.
APP_PORT=8080

# Friendly title shown in the browser tab and PWA install prompt.
APP_TITLE=Volley Scoreboard

# ---- Database ---------------------------------------------------------------
# SQLAlchemy connection URL for the application database (users, overlays,
# teams, presets, match reports). Defaults to a SQLite file under the data
# volume — fine for a single-container deployment. For PostgreSQL use e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/volley
# (the psycopg driver ships in the image — no rebuild needed). The schema is
# migrated to head automatically on startup (Alembic).
# DATABASE_URL=sqlite:////app/data/app.db

# ---- Accounts & sessions ----------------------------------------------------
# Secret used to harden login cookies and to sign match-report capability
# URLs. Auto-generated and persisted to data/.session_secret on first start
# if unset; set it explicitly to keep sessions/report links valid across
# redeploys and multiple instances.
# SESSION_SECRET=

# Whether new users may self-register from the public /register page. Unset
# (the default), registration stays open only until the first admin account
# is claimed and then closes automatically; set true/false to pin it. This is
# only the initial seed — once an admin toggles registration in the UI, the
# database value wins.
# REGISTRATION_OPEN=true

# Optional override for the first-admin claim token. When unset, a token is
# auto-generated and printed to the startup log (visible in `docker logs`);
# use it once at /claim-admin to create the first administrator.
# ADMIN_BOOTSTRAP_TOKEN=

# Set the Secure flag on the session cookie. Default: auto — Secure over
# HTTPS, off over plain HTTP. Force it to true when behind a TLS-terminating
# proxy that forwards as HTTP (and enable proxy headers).
# SESSION_COOKIE_SECURE=true

# Login session lifetime in hours. Default: 336 (14 days).
# SESSION_TTL_HOURS=336

# ---- Overlays ---------------------------------------------------------------
# Overlays are served in-process (built-in). Each overlay's OBS browser-source
# URL is the app's own /overlay/<token> link, surfaced under "My overlays".

# Public URL of this app for OBS-friendly overlay links when running behind a
# reverse proxy.
OVERLAY_PUBLIC_URL=

# Fallback team logo URL used when a team has none configured.
APP_DEFAULT_LOGO=

# Fallback locale for overlay rendering (when no ?lang= or persisted locale).
OVERLAY_LOCALE=

# ---- Match defaults ---------------------------------------------------------
MATCH_GAME_POINTS=25
MATCH_GAME_POINTS_LAST_SET=15
MATCH_SETS=5

# ---- Match reports & metrics ------------------------------------------------
# User accounts, sessions and roles are configured at the top of this file
# (DATABASE_URL / SESSION_SECRET / REGISTRATION_OPEN / ADMIN_BOOTSTRAP_TOKEN /
# SESSION_*). Every /api/v1/* scoreboard route is cookie + role gated.

# Open the print match-report routes (/match/{id}/report) to anonymous reads.
# Default (false): a report is readable only by its owner's session cookie or
# via an owner-minted signed share URL (POST /api/v1/matches/{id}/sign-url).
MATCH_REPORT_PUBLIC=false

# GET /metrics is unauthenticated by design — it exposes only aggregates
# (no payloads, no per-OID labels).

# ---- Logging ----------------------------------------------------------------
LOGGING_LEVEL=warning
LOG_FORMAT=text
LOG_FILE=
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUPS=5
LOG_REDACT=1

# Docker stdout/stderr ring buffer to keep a noisy incident from filling the
# host disk.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# ---- Behaviour --------------------------------------------------------------
ENABLE_MULTITHREAD=true

# Single knob overriding the TTL (seconds) of both customization caches.
# When unset, GameService defaults to 5s and Backend to 60s.
CUSTOMIZATION_CACHE_TTL_SECONDS=

# URL to a remote JSON file with configuration, fetched on startup.
REMOTE_CONFIG_URL=

# NOTE: Teams and presets are no longer configured via env vars — they live in
# the database and are managed in-app (per-user lists + admin-curated global
# catalog/groups/presets). An admin can bulk-load an existing catalog through
# the admin UI or POST /api/v1/admin/{teams,presets}/import, which accept the
# same JSON shapes the old APP_TEAMS / APP_THEMES vars used.

REST_USER_AGENT=

# ---- Webhooks ---------------------------------------------------------------
# Single endpoint, or multi-endpoint JSON via WEBHOOKS_JSON.
WEBHOOKS_URL=
WEBHOOKS_SECRET=
WEBHOOKS_JSON=

# CSV subset of events for the single-URL webhook (default: all events).
WEBHOOKS_EVENTS=

# Per-target POST timeout in seconds.
WEBHOOKS_TIMEOUT_S=5

# Allow webhook targets resolving to private/loopback IPs (SSRF opt-out;
# only for trusted-LAN deployments that call internal receivers).
WEBHOOKS_ALLOW_PRIVATE_IPS=false

# ---- Performance ------------------------------------------------------------
# Threshold (ms) above which ``GET /api/v1/state`` logs a slow-path warning.
PERF_GET_STATE_WARN_MS=50

# ---- Advanced tuning ----------------------------------------------------------
# Rarely-needed knobs. The defaults suit a normal deployment; each line shows
# its default. Not to be confused with SESSION_TTL_HOURS above (login cookie
# lifetime): SESSION_TTL_SECONDS evicts *idle in-memory game sessions*.
# SESSION_TTL_SECONDS=86400

# Login endpoint brute-force limiter: after MAX_FAILURES failed attempts per
# client IP within WINDOW seconds, auth routes answer 429 for BLOCK seconds.
# AUTH_RATE_LIMIT_MAX_FAILURES=10
# AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# AUTH_RATE_LIMIT_BLOCK_SECONDS=60

# Security response headers. HSTS is opt-in (set a max-age in seconds, e.g.
# 31536000, only on HTTPS-only deployments). The other three override the
# built-in Content-Security-Policy / Referrer-Policy / Permissions-Policy
# header values served with HTML responses.
# SECURITY_HSTS_SECONDS=
# SECURITY_CSP=
# SECURITY_REFERRER_POLICY=strict-origin-when-cross-origin
# SECURITY_PERMISSIONS_POLICY=geolocation=(), microphone=(), camera=(), payment=(), usb=()

# Per-overlay audit log rotation: rotate the active audit_<hash>.jsonl once it
# exceeds MAX_BYTES; keep at most MAX_FILES files (counting the active one).
# AUDIT_LOG_MAX_BYTES=5242880
# AUDIT_LOG_MAX_FILES=5

# Control/overlay WebSocket hub: per-socket broadcast send timeout, max
# concurrent subscribers per overlay, and the opt-in server heartbeat
# (interval 0 disables; keep CLIENT_TIMEOUT > 2 * INTERVAL when enabling).
# WS_BROADCAST_SEND_TIMEOUT_SECONDS=2.0
# WSHUB_MAX_CLIENTS_PER_OID=200
# Max OBS browser sources per overlay (/ws/<public_token>); the shareable
# public token must not allow unbounded fan-out.
# OBS_MAX_CLIENTS_PER_OVERLAY=100
# WSHUB_HEARTBEAT_INTERVAL_SECONDS=0
# WSHUB_CLIENT_TIMEOUT_SECONDS=60

# Outbound webhook retry policy (exponential backoff BASE * 2^attempt capped
# at MAX; ATTEMPTS counts retries after the first POST) and the cap on
# data/webhooks_dead_letter.jsonl records.
# WEBHOOK_RETRY_ATTEMPTS=3
# WEBHOOK_RETRY_BASE_SECONDS=1.0
# WEBHOOK_RETRY_MAX_SECONDS=8.0
# WEBHOOK_DEAD_LETTER_MAX_RECORDS=1000

# Preset catalogue caps: max preset-name length and global preset count.
# PRESETS_MAX_NAME_LEN=80
# PRESETS_MAX_RECORDS=500

# Hosted icon library. Uploaded/imported team logos are shrunk to fit
# ICONS_MAX_DIM on the longest side and re-encoded to WebP (quality
# ICONS_WEBP_QUALITY, stepping down until the file fits
# ICONS_MAX_STORED_BYTES). ICONS_MAX_UPLOAD_BYTES caps the raw upload;
# ICONS_MAX_PIXELS feeds the decompression-bomb guard. Personal libraries
# hold at most ICONS_MAX_PER_USER icons (global/admin icons are uncapped).
# The batch "import team logos" download uses ICONS_IMPORT_TIMEOUT_SECONDS
# per URL and converts at most ICONS_IMPORT_MAX_BATCH teams per request.
# ICONS_MAX_DIM=512
# ICONS_MAX_UPLOAD_BYTES=5242880
# ICONS_MAX_STORED_BYTES=524288
# ICONS_MAX_PER_USER=50
# ICONS_WEBP_QUALITY=82
# ICONS_MAX_PIXELS=24000000
# ICONS_IMPORT_TIMEOUT_SECONDS=10.0
# ICONS_IMPORT_MAX_BATCH=100
