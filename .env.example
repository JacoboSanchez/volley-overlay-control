# Volley Overlay Control — environment template.
#
# Copy this file to ``.env`` and adjust the values for your deployment.
# Lines that are commented out fall back to the defaults shown after ``=``.
# Secrets (passwords, tokens) MUST NOT be committed alongside this template.

# ---- Network ----------------------------------------------------------------
# Host port to expose the container on. ``80`` is the default for production
# behind a reverse proxy; pick something like ``8080`` for local dev.
EXTERNAL_PORT=8080

# Internal listen port — match the value in the Dockerfile HEALTHCHECK if you
# change it.
APP_PORT=8080

# Friendly title shown in the browser tab and PWA install prompt.
APP_TITLE=Scoreboard

# ---- Overlays ---------------------------------------------------------------
# overlays.uno cloud overlay ID. Leave empty if you only use built-in or
# custom overlays.
UNO_OVERLAY_OID=

# Public output URL on overlays.uno (e.g. https://app.overlays.uno/output/<code>).
UNO_OVERLAY_OUTPUT=

# External (third-party) custom overlay server URL.
APP_CUSTOM_OVERLAY_URL=
APP_CUSTOM_OVERLAY_OUTPUT_URL=

# Public URL of this app for OBS-friendly overlay links when running behind a
# reverse proxy.
OVERLAY_PUBLIC_URL=

# Comma-separated list of predefined overlays surfaced in the OID picker.
PREDEFINED_OVERLAYS=
HIDE_CUSTOM_OVERLAY_WHEN_PREDEFINED=

# Bearer token sent to the external overlay server, if it requires auth.
OVERLAY_SERVER_TOKEN=

# ---- Match defaults ---------------------------------------------------------
MATCH_GAME_POINTS=25
MATCH_GAME_POINTS_LAST_SET=15
MATCH_SETS=5

# ---- Authentication ---------------------------------------------------------
# JSON map of ``{"username": "password"}``. When unset the API is open.
SCOREBOARD_USERS=

# Single shared password for the /manage and /matches admin pages.
OVERLAY_MANAGER_PASSWORD=

# Open the match-report routes to anonymous reads.
MATCH_REPORT_PUBLIC=false

# ---- Logging ----------------------------------------------------------------
LOGGING_LEVEL=warning
LOG_FORMAT=text
LOG_FILE=
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUPS=5
LOG_REDACT=1

# Docker stdout/stderr ring buffer to keep a noisy incident from filling the
# host disk.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# ---- Behaviour --------------------------------------------------------------
ENABLE_MULTITHREAD=true
SINGLE_OVERLAY_MODE=true
ORDERED_TEAMS=true

APP_TEAMS=
APP_THEMES=
REST_USER_AGENT=

# ---- Webhooks ---------------------------------------------------------------
# Single endpoint, or multi-endpoint JSON via WEBHOOKS_JSON.
WEBHOOKS_URL=
WEBHOOKS_SECRET=
WEBHOOKS_JSON=

# ---- Performance ------------------------------------------------------------
# Threshold (ms) above which ``GET /api/v1/state`` logs a slow-path warning.
PERF_GET_STATE_WARN_MS=50
