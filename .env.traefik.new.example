# Environment for docker-compose.traefik.new.yml — copy to .env and edit.
#   cp .env.traefik.new.example .env
#
# In Arcane, paste these into the stack's "Environment" panel (or commit a
# .env next to the compose file). This variant PULLS the published `:new`
# image from Docker Hub instead of building from source.

# ── Required ──────────────────────────────────────────────────────────────────
# Docker Hub repository for the image published by the GitHub Action
# (the DOCKER_IMAGE / DOCKER_HUB_TAG used by .github/workflows/docker-publish-new.yml).
# e.g. youruser/volley-overlay-control
DOCKER_IMAGE=youruser/volley-overlay-control

# Public hostname Traefik routes to this app.
TRAEFIK_HOST=marcador.trebellos.eu

# Middleware chain applied to the HTTPS router (use your own Traefik
# middlewares). Example assumes a file-provider middleware named "secure-headers".
TRAEFIK_MIDDLEWARES=secure-headers@file

# ── Image (optional, defaults shown) ──────────────────────────────────────────
# Tag to deploy. The publish workflow pushes `:new` on every push to
# feat/multi-user-db; `pull_policy: always` re-pulls it on each (re)deploy.
DOCKER_IMAGE_TAG=new

# ── Traefik (optional, defaults shown) ────────────────────────────────────────
# Insecure entrypoint name as defined in your Traefik static config.
TRAEFIK_ENTRYPOINT=http

# ACME certificate resolver name as defined in your Traefik static config.
TRAEFIK_CERTRESOLVER=http

# Port the app listens on inside the container.
APP_PORT=8080

# Name of Traefik's existing external Docker network.
TRAEFIK_PROXY_NETWORK=proxy

# ── App (optional, defaults shown) ────────────────────────────────────────────
# Browser tab title.
APP_TITLE=Scoreboard

# Cookie/report-signing secret. Auto-generated + persisted to the data volume
# (data/.session_secret) if left blank; set it to pin the value across redeploys
# or fresh volumes. Generate one, e.g.:  openssl rand -hex 32
SESSION_SECRET=

# The app is behind Traefik's TLS termination (it only sees HTTP internally), so
# the Secure cookie flag is forced on by default. Leave true for HTTPS.
SESSION_COOKIE_SECURE=true

# Initial public self-registration. Off by default — admins create accounts.
# (An admin can toggle this in-app; the database value wins after first boot.)
REGISTRATION_OPEN=false

# First-admin claim token. If blank, one is generated and printed to the startup
# log on first run (read it with `docker logs`), then claimed at /claim-admin.
# Set it here to claim the admin deterministically.
ADMIN_BOOTSTRAP_TOKEN=

# Login session lifetime in hours (default 336 = 14 days).
SESSION_TTL_HOURS=

# Bearer token external overlay-server peers must present (auto-generated +
# persisted to data/.overlay_server_token if blank).
OVERLAY_SERVER_TOKEN=

# Host-header allow-list. Optional — Traefik already restricts the Host that
# reaches the app. If you set it, include localhost so the in-container
# healthcheck still passes, e.g.  ${TRAEFIK_HOST},localhost,127.0.0.1
TRUSTED_HOSTS=

# Gate GET /metrics behind the OVERLAY_SERVER_TOKEN bearer.
METRICS_REQUIRE_ADMIN=false

# Open the print match-report routes (/match/{id}/report) to anonymous reads.
MATCH_REPORT_PUBLIC=false

# ── Match defaults (optional) ─────────────────────────────────────────────────
MATCH_GAME_POINTS=25
MATCH_GAME_POINTS_LAST_SET=15
MATCH_SETS=5

# ── Logging (optional) ────────────────────────────────────────────────────────
LOGGING_LEVEL=warning
LOG_FORMAT=text

# ── PostgreSQL (optional — only when you uncomment the `db` service) ───────────
# Then also set:
#   DATABASE_URL=postgresql+psycopg://volley:volley_secret@db:5432/volley
# POSTGRES_USER=volley
# POSTGRES_PASSWORD=volley_secret
# POSTGRES_DB=volley
