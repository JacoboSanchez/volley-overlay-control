root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4
max_line_length = 120

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,md,html,css,scss}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{png,jpg,jpeg,gif,ico,webp,woff,woff2,ttf,otf}]
trim_trailing_whitespace = false
insert_final_newline = false
