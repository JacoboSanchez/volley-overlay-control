    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "openapi-typescript": "^7.13.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
